---
interface Props {
  title?: string;
  comments?: boolean;
}

const { title, comments = false } = Astro.props;
const pageTitle = title ? `${title} — Marginalia` : 'Marginalia';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <link rel="alternate" type="application/rss+xml" title="Marginalia" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />
    <script is:inline>
      (function () {
        const pref = localStorage.getItem('theme');
        if (pref === 'dark' || pref === 'light') {
          document.documentElement.dataset.theme = pref;
        }
      })();
    </script>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="site-title">Marginalia</a>
        <button id="theme-toggle" type="button" aria-label="Toggle theme">
          <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      {comments && (
        <div class="comments">
          <div class="comments-header">
            <span class="comments-label">Comments</span>
            <span class="comments-closed">closed</span>
          </div>
          <p class="comments-message">
            If you've read this far, you probably know how to reach me.
            Grab a beer sometime, or write me a letter.
          </p>
        </div>
      )}
    </footer>
    <script is:inline>
      document.getElementById('theme-toggle').addEventListener('click', function () {
        const root = document.documentElement;
        const current = root.dataset.theme;
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        let next;
        if (!current) {
          // Currently following system — toggle to the opposite
          next = systemDark ? 'light' : 'dark';
        } else if (current === 'dark') {
          next = 'light';
        } else {
          next = 'dark';
        }

        // If the new choice matches system preference, clear the override
        const nextMatchesSystem = (next === 'dark') === systemDark;
        if (nextMatchesSystem) {
          delete root.dataset.theme;
          localStorage.removeItem('theme');
        } else {
          root.dataset.theme = next;
          localStorage.setItem('theme', next);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --font-body: 'Spectral', Georgia, 'Iowan Old Style', serif;
    --font-heading: system-ui, -apple-system, 'Segoe UI', sans-serif;
    --font-mono: 'Berkeley Mono', 'Fira Code', Consolas, monospace;
    --color-bg: #faf8f4;
    --color-surface: #ffffff;
    --color-text: #2e2e2e;
    --color-muted: #6e6e6e;
    --color-accent: #8b4513;
    --color-rule: #d5cec4;
    --max-width: 36rem;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-bg: #1c1a17;
      --color-surface: #24211e;
      --color-text: #d5cec4;
      --color-muted: #908780;
      --color-accent: #c9956b;
      --color-rule: #3d3832;
    }
  }

  :root[data-theme='dark'] {
    --color-bg: #1c1a17;
    --color-surface: #24211e;
    --color-text: #d5cec4;
    --color-muted: #908780;
    --color-accent: #c9956b;
    --color-rule: #3d3832;
  }

  :root[data-theme='light'] {
    --color-bg: #faf8f4;
    --color-surface: #ffffff;
    --color-text: #2e2e2e;
    --color-muted: #6e6e6e;
    --color-accent: #8b4513;
    --color-rule: #d5cec4;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    font-size: 18px;
    background: var(--color-bg);
  }

  body {
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-surface);
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1rem;
    line-height: 1.75;
    letter-spacing: 0.01em;
  }

  header {
    margin-bottom: 3rem;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-muted);
    padding: 0.25rem;
    line-height: 0;
  }

  #theme-toggle:hover {
    color: var(--color-text);
  }

  /* Show moon in light mode, sun in dark mode */
  .icon-sun { display: none; }
  .icon-moon { display: inline; }

  @media (prefers-color-scheme: dark) {
    .icon-sun { display: inline; }
    .icon-moon { display: none; }
  }

  :root[data-theme='dark'] .icon-sun { display: inline; }
  :root[data-theme='dark'] .icon-moon { display: none; }
  :root[data-theme='light'] .icon-sun { display: none; }
  :root[data-theme='light'] .icon-moon { display: inline; }

  .site-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-style: italic;
    font-weight: 300;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .site-title:hover {
    color: var(--color-text);
  }

  main {
    min-height: 60vh;
  }

  h1, h2, h3 {
    font-family: var(--font-heading);
    letter-spacing: 0;
  }

  h1 {
    font-size: 1.6rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 0.5rem;
  }

  h2 {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }

  h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }

  a {
    color: var(--color-accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  a:hover {
    text-decoration-thickness: 2px;
  }

  blockquote {
    border-left: 2px solid var(--color-rule);
    margin: 1.5rem 0;
    padding: 0 1rem;
    color: var(--color-muted);
    font-style: italic;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: color-mix(in srgb, var(--color-text) 8%, transparent);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }

  pre {
    overflow-x: auto;
    padding: 1rem;
    border-radius: 4px;
  }

  pre code {
    background: none;
    padding: 0;
  }

  hr {
    border: none;
    border-top: 1px solid var(--color-rule);
    margin: 2rem 0;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  footer {
    margin-top: 4rem;
  }

  .comments {
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
  }

  .comments-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-rule);
  }

  .comments-label {
    font-weight: 600;
    color: var(--color-muted);
  }

  .comments-closed {
    font-size: 0.75rem;
    color: var(--color-muted);
    background: color-mix(in srgb, var(--color-text) 8%, transparent);
    padding: 0.1em 0.5em;
    border-radius: 3px;
  }

  .comments-message {
    color: var(--color-muted);
    font-style: italic;
    margin: 0;
  }

  .post-date {
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-list li {
    margin-bottom: 1.5rem;
  }

  .post-list a {
    font-size: 1.1rem;
    text-decoration: none;
  }

  .post-list a:hover {
    text-decoration: underline;
  }

  .post-body {
    margin-top: 2rem;
  }

  .post-body p {
    margin: 1rem 0;
  }
</style>
