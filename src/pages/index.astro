---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base>
  <section class="intro">
    <p>
      Bob Long's scattered commentary on things he's been thinking too hard about.
      Not a blog. Not a journal.
      Just <a href={`${import.meta.env.BASE_URL}/posts/about-marginalia/`}>notes in the margins</a>.
    </p>
  </section>
  <hr />
  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <time class="post-date" datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <br />
        <a href={`${import.meta.env.BASE_URL}/posts/${post.id}/`}>{post.data.title}</a>
      </li>
    ))}
  </ul>
</Base>
